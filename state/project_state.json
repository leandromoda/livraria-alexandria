  },
  "data_layer": {
    "production": {
      "provider": "Supabase",
      "status": "connected",
      "rls_public_read": true,
      "tables": [
        "livros",
        "listas",
        "listas_livros",
        "categorias",
        "livros_categorias",
        "ofertas",
        "oferta_clicks",
        "autores",
        "livros_autores"
      ]
    },
    "staging": {
      "provider": "SQLite",
      "role": "Ingest + Enrichment + QA + Dedup",
      "status": "operational",
      "path": "scripts/data/books.db",
      "resume_capability": true,
      "editorial_fields": [
        "is_book",
        "editorial_score",
        "descricao_base"
      ],
      "runtime_mode": "WAL_enabled_busy_timeout_60s",
      "tables": [
        "livros",
        "autores",
        "livros_autores",
        "dedup_log",
        "ingest_runs",
        "pipeline_state"
      ]
    }
  },
  "synopsis_architecture": {
    "model": "factual_transformation_pipeline",
    "objective": "eliminate_llm_hallucination",
    "strategy": [
      "mandatory_source_description",
      "fact_extraction",
      "structured_abstraction",
      "constrained_synopsis_generation",
      "json_schema_validation"
    ],
    "llm_constraints": {
      "model": "gemini-2.5-flash (primary) / gemma2:9b (fallback)",
      "allowed_operations": [
        "extraction",
        "compression",
        "structured synthesis"
      ],
      "forbidden_operations": [
        "open narrative reconstruction",
        "external knowledge insertion",
        "creative expansion without source"
      ]
    }
  },
  "ingest_pipeline": {
    "status": "operational_idioma_editorial_aware",
    "execution": {
      "entrypoint": "scripts/main.py",
      "mode": "menu_driven",
      "interrupt_resume": true,
      "heartbeat": "30s",
      "logging": "timestamped_terminal",
      "idioma_partitioning": true
    },
    "state_management": {
      "progress_storage": "SQLite",
      "storage_path": "scripts/data/books.db",
      "granularity": [
        "per_step",
        "per_record",
        "per_batch"
      ],
      "resume_strategy": "auto_continue_from_last_offset",
      "segmented_by_language": true
    },
    "cluster_strategy": {
      "type": "library_grade_taxonomy",
      "scope": "expanded_exhaustive",
      "clusters_pt": 42,
      "clusters_en": 40,
      "clusters_es": 20,
      "clusters_it": 10
    },
    "steps": [
      {
        "order": 1,
        "name": "Offer Seed",
        "status": "operational",
        "idioma_aware": true,
        "persistence": "scripts/data/books.db"
      },
      {
        "order": 2,
        "name": "Enrich Descricao",
        "status": "operational",
        "idioma_aware": true,
        "persistence": "scripts/data/books.db",
        "description": "Enriquece descricao via Google Books API (com key) ou OpenLibrary"
      },
      {
        "order": 4,
        "name": "Slugify",
        "status": "operational",
        "idioma_aware": true
      },
      {
        "order": 5,
        "name": "Slugify Autores",
        "status": "operational",
        "description": "Extrai autores únicos de livros.autor, gera slugs, popula tabelas autores e livros_autores no SQLite",
        "script": "scripts/steps/slugify_autores.py",
        "idioma_aware": false,
        "multi_autor_support": true,
        "separator": ";"
      },
      {
        "order": 6,
        "name": "Deduplicate",
        "status": "operational",
        "idioma_aware": true,
        "merge_scope": "intra-language"
      },
      {
        "order": 7,
        "name": "Synopsis Generation",
        "status": "operational_factual_fsm_pipeline",
        "idioma_aware": true,
        "llm": "gemini-2.5-flash (primary) / gemma2:9b (fallback)",
        "executor": "Markdown Agent Executor FSM",
        "agent_path": "agents/synopsis",
        "pipeline_architecture": [
          "fact_extractor",
          "abstract_structurer",
          "synopsis_writer",
          "synopsis_validator"
        ],
        "generation_mode": "transformational_not_generative",
        "source_required": "descricao_base",
        "hallucination_control": [
          "fact_extraction",
          "structured_abstraction",
          "constrained_synthesis",
          "json_validation"
        ],
        "on_fail": "continue (livro pulado, status_synopsis permanece 0)",
        "validator_min_words": 80,
        "validator_max_words": 160
      },
      {
        "order": 6,
        "name": "Review",
        "status": "operational_editorial_classifier",
        "idioma_aware": true,
        "llm": "gemini-2.5-flash (primary) / gemma2:9b (fallback)",
        "outputs": [
          "idioma_resolved",
          "is_book",
          "editorial_score"
        ],
        "description": "Classificação editorial + detecção de idioma. Roda ANTES da sinopse."
      },
      {
        "order": 8,
        "name": "Cover Enrichment",
        "status": "operational",
        "idioma_aware": true,
        "fallback": "status_cover=2 (sem capa — não bloqueia quality gate)",
        "sources": [
          "amazon (isbn direct URL)",
          "google_books",
          "openlibrary"
        ],
        "placeholder_check": "min 5000 bytes"
      },
      {
        "order": 9,
        "name": "Quality Gate",
        "status": "operational_hard_validation",
        "idioma_aware": true,
        "hard_blocks": [
          "status_slug != 1",
          "status_synopsis != 1",
          "status_review != 1",
          "status_cover NOT IN (1,2)",
          "sinopse < 400 chars",
          "idioma UNKNOWN",
          "idioma divergente",
          "is_book = 0",
          "editorial_score < 0"
        ],
        "scoring_model": {
          "fields": [
            "slug",
            "descricao",
            "imagem_url",
            "status_review"
          ],
          "min_score_publish": 3
        }
      },
      {
        "order": 10,
        "name": "Publish",
        "status": "operational",
        "idioma_aware": true,
        "id_strategy": "uuid5 (namespace fixo + local_id)",
        "round_trip_id": true,
        "target": "Supabase.livros",
        "blockers": [
          "quality_gate_fail"
        ],
        "upsert_mode": "POST ?on_conflict=slug",
        "prefer_header": "resolution=merge-duplicates,return=representation",
        "fields_published": [
          "id",
          "titulo",
          "slug",
          "autor",
          "descricao(=sinopse)",
          "isbn",
          "ano_publicacao",
          "imagem_url",
          "is_publishable",
          "quality_score",
          "is_book",
          "last_quality_check",
          "publish_blockers",
          "created_at",
          "updated_at"
        ],
        "on_409": "UPSERT gracioso — marca como publicado localmente"
      },
      {
        "order": 11,
        "name": "Publish Autores",
        "status": "operational",
        "description": "Publica autores e relações livros_autores no Supabase",
        "script": "scripts/steps/publish_autores.py",
        "target": "Supabase.autores + Supabase.livros_autores",
        "upsert_mode": "POST ?on_conflict=slug",
        "idioma_aware": false
      },
      {
        "order": 12,
        "name": "List Composer",
        "status": "operational",
        "description": "Geração automática de listas SEO por categoria com filtro editorial anti–thin content",
        "script": "scripts/steps/list_composer.py",
        "tables_created": [
          "listas",
          "listas_livros"
        ],
        "generation_rules": {
          "min_books_per_list": 6,
          "max_books_per_list": 12,
          "max_lists_per_run": 200,
          "min_high_score_books": 2,
          "min_editorial_score": 2
        },
        "source": "livros publicados",
        "execution_mode": "manual_menu_option",
        "menu_option": 13
      }
    ]
  },
  "validated_routes": [
    "/",
    "/listas",
    "/livros",
    "/livros/[slug]",
    "/listas/[slug]",
    "/categorias",
    "/categorias/[slug]",
