# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
acess.txt
/.claude/worktrees/

# pipeline artifacts
runtime/tmp/
**/__pycache__/
scripts/alexandria.db
scripts/data/*.db-wal
scripts/data/*.db-shm
scripts/data/books.db
scripts/data/backup/*.db
scripts/data/audit_*.json
scripts/data/blacklist.json
scripts/data/gemini_usage.json
scripts/data/pipeline_*.log
test.txt

# state exports (auto-gerados) — exceto o estado do projeto
state/*
!state/project_state.json
/scripts/data/seeds
