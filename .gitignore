# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
acess.txt
/.claude/worktrees/

# pipeline artifacts
runtime/tmp/
**/__pycache__/
scripts/alexandria.db
scripts/data/*.db-wal
scripts/data/*.db-shm
scripts/data/books.db
scripts/data/backup/
scripts/data/seeds/
scripts/data/audit_*.json
scripts/data/blacklist.json
scripts/data/gemini_usage.json
scripts/data/claude_usage.json
scripts/data/gargalo_plan.json
scripts/data/synopsis_input.json
scripts/data/synopsis_output.json
scripts/data/categorize_input.json
scripts/data/categorize_output.json
scripts/data/offer_list.json
scripts/data/batch_measure_results.jsonl
scripts/data/batch_measure_run.log
scripts/data/.fuse_hidden*
# logs de runtime (pipeline_*.log + NNNN_audit_*.json) — consumidos pelo log_analysis e arquivados
scripts/data/logs/
# batch: lotes transitórios de input/output são runtime (ignorar não afeta o glob do Python).
# Mantém rastreáveis os relatórios commitados pelo orquestrador (*_consistency*.json).
scripts/data/batch/*_synopsis_input.json
scripts/data/batch/*_synopsis_output.json
scripts/data/batch/*_categorize_input.json
scripts/data/batch/*_categorize_output.json
scripts/data/batch/*_author_bio_input.json
scripts/data/batch/*_author_bio_output.json
scripts/data/batch/processed_synopsis/
scripts/data/batch/processed_categorize/
scripts/data/batch/processed_author_bio/
scripts/data/log_analysis/processed_logs/
test.txt

# state exports (auto-gerados) — exceto o estado do projeto
state/*
!state/project_state.json
agents/Claude Init.txt
